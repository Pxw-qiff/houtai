# ==================== 数据库配置 ====================
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=chuamgwei_gateway
MYSQL_USER=chuamgwei
MYSQL_PASSWORD=change-me

# ==================== JWT 密钥（Node 和 Java 共用） ====================
JWT_SECRET=change-me

# ==================== 积分内部接口密钥 ====================
INTERNAL_CREDIT_SECRET=change-me

# ==================== Redis 配置 ====================
# Redis 密码可选，留空表示不设密码
REDIS_PASSWORD=
REDIS_DATABASE=0

# ==================== 端口映射（可选，默认值见 docker-compose.yml） ====================
MYSQL_PORT=3306
REDIS_PORT=6379
NODE_LOGIN_PORT=3100
JAVA_BACKEND_PORT=8080
FRONTEND_PORT=5174

# ==================== new-api 配置 ====================
# new-api 服务地址（Node 同步用户时调用）
NEW_API_BASE_URL=http://new-api:3000
# new-api 内部同步密钥（Node 同步用户、new-api 回调 Java 积分都用这个）
NEW_API_INTERNAL_SECRET=change-me
# 同步超时时间（毫秒）
NEW_API_SYNC_TIMEOUT_MS=5000
# new-api Session 密钥（多机部署时必须统一）
NEW_API_SESSION_SECRET=change-me
# new-api 端口
NEW_API_PORT=3000
# 是否启用外部积分账本（启用后 new-api 不再自己扣 quota）
CHUAMGWEI_CREDIT_ENABLED=true
# 外部积分调用超时（毫秒）
CHUAMGWEI_CREDIT_TIMEOUT_MS=5000

# ==================== 支付宝配置（可选，沙箱或生产） ====================
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_SERVER_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=http://127.0.0.1:8080/v1/recharge/callback/alipay
INTERNAL_CREDIT_SECRET=0b41287c5b059b123b5d3a9c70bf1a5502d692780a3dc0e976304c62aec2febf
NEW_API_INTERNAL_SECRET=4a283276577ee7de418e1169e6dbc039a2e222630cd3a4cd21a10a2a343993ea
NEW_API_SESSION_SECRET=9696942a050c40319904a0ec633aeffe4f504a5f540e07daba724217c0aaac1c